{
  "name": "component-library-2026",
  "version": "1.0.0",
  "description": "Comic Relief React component library built with Vite and styled-components",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "lint": "eslint src",
    "lint-fix": "yarn lint --fix",
    "test:unit": "jest",
    "test:unit:update": "jest -u",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e--h": "playwright test --project=chromium --headed"
  },
  "jest": {
    "verbose": true,
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "<rootDir>/playwright/",
      "<rootDir>/dist/",
      "<rootDir>/node_modules/"
    ],
    "moduleNameMapper": {
      "\\.(css|jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/assetTransformer.js"
    }
  },
  "peerDependencies": {
    "@hookform/resolvers": ">=3",
    "@splidejs/react-splide": ">=0.7",
    "lazysizes": ">=5",
    "lodash": ">=4",
    "moment": ">=2",
    "prop-types": ">=15",
    "pure-react-carousel": ">=1",
    "react": ">=18",
    "react-canvas-confetti": ">=2",
    "react-currency-format": ">=1",
    "react-dom": ">=18",
    "react-hook-form": ">=7",
    "react-modal": ">=3",
    "react-range-slider-input": ">=3",
    "react-responsive": ">=10",
    "react-spinners": ">=0.14",
    "react-uid": ">=2",
    "styled-components": ">=6",
    "youtube-player": ">=5",
    "yup": ">=1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@playwright/test": "^1.38.1",
    "@vitejs/plugin-react": "^4.3.1",
    "babel-jest": "^29.7.0",
    "babel-plugin-styled-components": "^2.1.4",
    "eslint": "^7.32.0",
    "eslint-config-airbnb": "^18.2.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-styled-components": "^7.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "semantic-release": "^17.4.6",
    "styled-components": "^6.1.13",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  },
  "dependencies": {}
}
